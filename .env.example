# FourCommunity Frontend Environment Variables

# Backend API URL (no trailing slash)
VITE_API_URL=http://localhost:3001

# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site Configuration
VITE_SITE_URL=http://localhost:5173

# Google OAuth (optional)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Razorpay Configuration (REQUIRED for payments)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Admin Security (REQUIRED for admin access)
VITE_ADMIN_PASSWORD=your-strong-admin-password

# PostHog Analytics (REQUIRED for analytics)
VITE_POSTHOG_KEY=phc_your_posthog_project_api_key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Supabase Server-Side (for Vercel API routes - NOT prefixed with VITE_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here